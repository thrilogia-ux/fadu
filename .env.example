# Base de datos PostgreSQL (Neon, Vercel Postgres, Supabase, local, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
#
# --- Vercel + Supabase (muy común que el home/API queden vacíos si esto está mal) ---
# En el dashboard de Supabase: Settings → Database → "Connection string" → URI.
# Para serverless (Vercel) usá el POOLER en modo **Transaction** (puerto 6543), no la
# conexión directa 5432, y agregá parámetros Prisma:
#   ?pgbouncer=true&connection_limit=1&sslmode=require
# Ejemplo de host: aws-0-REGION.pooler.supabase.com:6543
# Copiá EXACTAMENTE esa URL en Vercel → Project → Settings → Environment Variables → DATABASE_URL (Production).
# Verificación en producción: https://TU-DOMINIO/api/health → "database":"ok". Si es "error", /api/products devuelve [] y el home queda sin productos.
# Supabase: Settings → Database → si el proyecto está pausado, reanudalo.

# Auth.js - generar con: npx auth secret
AUTH_SECRET=""

# URL de la app (en dev: http://localhost:3000)
AUTH_URL="http://localhost:3000"

# Pública del sitio (Production en Vercel). Mejora el fallback server→API del home.
# Ejemplo: https://fadustore.vercel.app
# NEXT_PUBLIC_SITE_URL="https://fadustore.vercel.app"

# Google OAuth (crear en https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Vercel Blob - subida de imágenes en admin (crear Blob store en Vercel > Storage)
# Se genera automáticamente al crear el store; local: vercel env pull
# BLOB_READ_WRITE_TOKEN=""

# Resend - envío de emails (confirmación de venta, QR para retiro)
# 1. Crear cuenta en resend.com
# 2. Dashboard > API Keys > Create API Key
# 3. RESEND_TEST_TO: solo aplica con `next dev` (local). En Vercel/producción el código lo ignora y usa el email del cliente.
RESEND_API_KEY="re_xxxx..."
# RESEND_TEST_TO="tu@email.com"
# RESEND_FROM_EMAIL="Fadu.store <ventas@tudominio.com>"  # opcional; default: onboarding@resend.dev
